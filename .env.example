# Copy to .env and fill in. The .env file is gitignored.

# Required
OPENAI_API_KEY=sk-...

# Models (optional)
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=large

# Chunking / retrieval tuning (optional)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# Paths (optional — defaults shown)
CHROMA_DB_PATH=./db
AUDIO_DIR=data/audio
TRANSCRIPTIONS_DIR=data/transcriptions
STATUS_FILE=data/status.json
